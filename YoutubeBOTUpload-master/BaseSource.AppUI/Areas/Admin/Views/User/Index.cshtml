@using BaseSource.ViewModels.Report;
@model List<UserAdminInfoDto>
@{
    ViewData["Title"] = "Danh sách người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var report = ViewBag.Report as ReportDto;
    var managers = ViewBag.Managers as List<UserAdminInfoDto>;
    var index = 1;
    var managerChoose = ViewBag.ManagerChooses as List<string>;
}
<section class="section">
    <div class="section-header">
        @if (User.IsInRole("Admin"))
        {
            <h1>Chọn manager</h1>

            <div class="section-header-breadcrumb w-75">
                <select class="form-control select2" id="managerChoose" multiple>
                    @foreach (var item in managers)
                    {
                        <option value="@item.Id" selected="@(managerChoose.Any(x=>x==item.Id))">@item.UserName</option>
                    }
                </select>
                <button class="btn btn-primary ml-1" onclick="reloadPage()">Search</button>
            </div>
        }
        else
        {
            <h1>@ViewData["Title"]</h1>
        }
    </div>

    <div class="section-body">

        <div class="row mb-4">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-stats-title border-bottom" style="border-color: #f1f5f9 !important;">
                        Báo cáo hệ thống
                    </div>
                    <div class="card-stats-items">
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalChannel</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-success">Tính năng Kênh</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#10b981;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@(report.TotalBotConnected)/@(report.TotalBot)</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-primary">Số lượng BOT</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#6366f1;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalUser</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-info">Người dùng</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#0ea5e9;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalRenderInRun</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-primary" style="background:rgba(93,103,223,0.12);color:#5d67df;">Render Active</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#5d67df;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalRenderUpload</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-info" style="background:rgba(14,165,233,0.12);color:#0284c7;">Đang Upload</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#0284c7;"></div>
                        </div>
                        <div class="card-stats-item text-center border-0">
                            <div class="card-stats-item-count">@report.TotalRenderPending</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-warning">Job Chờ</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#f59e0b;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Danh sách người dùng</h4>
                        <a class="btn btn-success" href="/admin/user/create">Tạo mới</a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="tableAllUser">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>Action</th>
                                        <th>Vai trò</th>
                                        <th>Người dùng</th>
                                        <th>Manager</th>
                                        <th>Mật khẩu</th>
                                        <th>Số kênh</th>
                                        <th>Số BOT</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                                                      <td>
                                                <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                                    <a class="btn btn-secondary bg-white text-brand border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/channel/user?userId=@(item.Id)&username=@(item.UserName)">
                                                        <i class="fas fa-link mr-1"></i> Kênh
                                                    </a>
                                                    <a class="btn btn-secondary bg-white text-emerald-600 border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/bot/user?userId=@(item.Id)&username=@(item.UserName)">
                                                        <i class="fas fa-server mr-1"></i> BOT
                                                    </a>
                                                    <button class="btn btn-secondary bg-white text-rose-500 border border-slate-200 btnDelete" style="font-size:11px; padding:4px 8px;" data-id="@item.Id">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                    <button class="btn btn-secondary bg-white text-amber-500 border border-slate-200 btnResetPassword" style="font-size:11px; padding:4px 8px;" data-id="@item.Id" data-user="@item.UserName">
                                                        <i class="fas fa-key"></i> Pass
                                                    </button>
                                                    @if (User.IsInRole("Admin"))
                                                    {
                                                        <button class="btn btn-secondary bg-white text-sky-500 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="updateUser('@item.Id','@item.UserIdManager')">
                                                            <i class="fas fa-edit"></i> Edit
                                                        </button>
                                                    }
                                                </div>
                                            </td>                                   </td>
                                            <td>
                                                @if (item.Roles.Any(x => x == "Admin"))
                                                {
                                                    <span class="badge badge-danger">@(string.Join(",", item.Roles))</span>
                                                }
                                                else if (item.Roles.Any(x => x == "Manager"))
                                                {
                                                    <span class="badge badge-warning">Manager</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-success">User</span>
                                                }
                                            </td>
                                            <td>@item.UserName</td>
                                            <td>@item.UserManager</td>
                                            @if (!string.IsNullOrEmpty(item.UserUpdate))
                                            {
                                                <td>[@(item.UserUpdate)- @(item.UpdatedTime?.ToString("dd/MM/yyyy"))]</td>
                                            }
                                            else
                                            {
                                                <td></td>
                                            }
                                            <td><span class="badge badge-success">@item.TotalChannel</span> </td>
                                            <td><span class="badge badge-danger">@item.TotalBOT</span></td>


                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" tabindex="-1" role="dialog" id="createUserModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" id="formcreateUser" action="/admin/User/Create">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm mới người dùng</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-4">
                        <label class="">UserName</label>
                        <div class="">
                            <input name="UserName" placeholder="Nhập username người dùng" class="form-control" />
                            <span class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group mb-4">
                        <label class="">Mật khẩu</label>
                        <div class="">
                            <input name="Password" placeholder="Nhập mật khẩu người dùng" class="form-control" />
                            <span class="text-danger"></span>
                        </div>
                    </div>

                    @*<div class="form-group mb-4">
                    <label class="">Link telegram</label>
                    <div class="">
                    <input type="number" name="LinkTelegram" placeholder="Nhập link telegram" class="form-control" />
                    <span class="text-danger"></span>
                    </div>
                    </div>*@
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Tạo mới</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" role="dialog" id="editUserModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" id="formeditUser" action="/admin/User/UpdateTelegram">
                <input name="UserId" type="hidden" />
                <div class="modal-header">
                    <h5 class="modal-title">Cập nhật</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-4">
                        <label class="">Manager <span class="text-danger">(Nếu người dùng là Manager, không chọn dòng này)</span></label>
                        <div class="">
                            <div class="">
                                <select name="UserIdManager" required class="form-control select2">
                                    <option>-- Chọn ---</option>
                                    @foreach (var item in managers)
                                    {
                                        <option value="@item.Id">@item.UserName</option>
                                    }
                                </select>

                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" tabindex="-1" role="dialog" id="deleteUserModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" id="formDeleteUser" action="/admin/User/Delete">
                <div class="modal-header">
                    <h5 class="modal-title">Xóa người dùng?</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Bạn có muốn xóa người dùng này?</p>
                    <input class="form-control" name="userId" type="hidden" />
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Xác nhận</button>

                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" tabindex="-1" role="dialog" id="resetPasswordModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" id="formResetPassword" action="/admin/User/ResetPassword">
                <div class="modal-header">
                    <h5 class="modal-title">Reset mật khẩu người dùng :<span class="text-danger text-userName"></span></h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-4">
                        <label class="">Nhập mật khẩu mới</label>
                        <div class="">
                            <input name="Password" required placeholder="Nhập mật khẩu mới" class="form-control" />
                            <span class="text-danger"></span>
                        </div>
                    </div>
                    <input class="form-control" name="userId" type="hidden" />
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Xác nhận</button>

                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#tableAllUser").DataTable({});

            $('body').on('click', '.btnReset', function () {
                let id = $(this).attr('data-id');
                $('#formResetPassword input[name="userId"]').val(id);
            });
            $('body').on('click', '.btnDelete', function () {
                $('#deleteUserModal').modal('show');
                let id = $(this).attr('data-id');
                $('#formDeleteUser input[name="userId"]').val(id);
            });
            $('body').on('click', '.btnTelegram', function () {
                $('#telegramModal').modal('show');

                let id = $(this).attr('data-id');
                let telegrams = $(this).attr('data-tele');
                $('#formTelegram input[name="UserId"]').val(id);
                $('#formTelegram input[name="Telegram"]').val(telegrams);
            });

            $('body').on('click', '.btnResetPassword', function () {
                let id = $(this).attr('data-id');
                let user = $(this).attr('data-user');
                $('.text-userName').html(user);
                $('#formResetPassword input[name="userId"]').val(id);
                $('#resetPasswordModal').modal('show');
                //$('#telegramModal').modal('show');


                //let telegrams = $(this).attr('data-tele');
                //$('#formTelegram input[name="UserId"]').val(id);
                //$('#formTelegram input[name="Telegram"]').val(telegrams);
            });


        });
        function updateUser(id, userIdManager) {
            $('#editUserModal').modal('show');
            $('#formeditUser input[name="UserId"]').val(id);
            $('#formeditUser select[name="UserIdManager"]').val(userIdManager);
        }


    </script>
}
