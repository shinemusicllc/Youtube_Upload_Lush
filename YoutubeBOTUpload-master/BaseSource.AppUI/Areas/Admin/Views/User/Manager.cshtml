@model List<UserAdminInfoDto>
@{
    ViewData["Title"] = "Danh sách Manager";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var index = 1;
}

<section class="section">
    <div class="section-header">
        <h1>@ViewData["Title"]</h1>
        <div class="section-header-breadcrumb">
            <div class="breadcrumb-item active"><a href="#">Home</a></div>
            <div class="breadcrumb-item"><a href="#">Danh sách </a></div>
            <div class="breadcrumb-item">@ViewData["Title"]</div>
        </div>
    </div>
    <div class="section-body">
        <div class="row">
                <div class="elevated-card p-0">
                    <div class="card-header border-bottom-0 pb-0 d-flex justify-content-between align-items-center">
                        <h4 class="text-brand">@ViewData["Title"]</h4>
                        <button class="btn btn-primary btn-sm px-3" data-toggle="modal" data-target="#addRoleModal">
                            <i class="fas fa-plus mr-1"></i> Thêm TK Manager
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="tableAllManager">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>Người dùng</th>
                                        <th>Mật khẩu</th>
                                       
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>@item.UserName</td>
                                            <td>@item.Password</td>
                                            <td>
                                                <button class="btn btn-secondary bg-white text-rose-500 border border-slate-200 btn-removeRole" 
                                                        style="font-size:11px; padding:4px 8px;" 
                                                        data-id="@item.UserName">
                                                    <i class="fas fa-user-minus mr-1"></i> Hủy Role
                                                </button>
                                            </td>
                                        </tr>

                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="modal fade" tabindex="-1" role="dialog" id="addRoleModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" action="/admin/User/UpdateRoleManager">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm Quyền Quản lý cho người dùng</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Nhập username người người</p>
                    <input class="form-control" name="username" placeholder="Nhập UserName người dùng" />
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Xác nhận</button>

                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" tabindex="-1" role="dialog" id="removeRoleModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" id="formRemoveRole" action="/admin/User/UpdateRoleManager">
                <div class="modal-header">
                    <h5 class="modal-title">Hủy Quyền Quản lý cho người dùng</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Bạn có muốn hủy Quyền Quản lý của người dùng này?</p>
                    <input class="form-control" type="hidden" name="username" />
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Xác nhận</button>

                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts{
    <script>

        $(document).ready(function () {

            $("#tableAllManager").DataTable({

            });

            //$('#telegramModal').modal('show');
            $('body').on('click', '.btn-removeRole', function () {

                $('#removeRoleModal').modal('show');
                let userName = $(this).attr('data-id');
                $('#formRemoveRole input[name="username"]').val(userName);
            })
        });

    </script>
}