@using BaseSource.ViewModels.ChannelAdmin;
@model List<UserChannelAdminInfoDto>
@{
    var botName = ViewBag.BotName;
    ViewData["Title"] = $"Danh sách Người dùng của Kênh ({ViewBag.ChannelName})";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var index = 1;
    var users = ViewBag.Users as List<UserAdminInfoDto>;
}
<section class="section">
    <div class="section-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <h1 class="mb-2">@ViewData["Title"]</h1>
        <div class="section-header-breadcrumb m-0">
            <div class="breadcrumb-item active"><a href="#">Hệ thống</a></div>
            <div class="breadcrumb-item"><a href="#">Danh sách Kênh</a></div>
            <div class="breadcrumb-item">Người dùng của Kênh</div>
        </div>
    </div>

    <div class="section-body">
        @*<h2 class="section-title">@ViewData["Title"]</h2>*@

        <div class="row">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-header border-bottom-0 pb-0 d-flex justify-content-between align-items-center">
                        <h4 class="text-brand">@ViewData["Title"]</h4>
                        <button class="btn btn-primary shadow-sm shadow-brand/30 rounded-lg px-4 btnAddUser"><i class="fas fa-plus mr-2"></i>Thêm User</button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="tableUserOfChannel">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>Người dùng</th>
                                        @*<th>Mật khẩu</th>*@
                                        <th>Số kênh</th>
                                        <th>Số Bot</th>

                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>@item.UserName</td>
                                            @*<td>****</td>*@
                                            <td><span class="badge badge-primary">@item.TotalChannel</span></td>
                                            <td><span class="badge badge-primary">@item.TotalBot</span></td>
                                            <td>
                                                <div style="display: flex; flex-direction: column; gap: 4px; min-width: 100px;">
                                                    <a class="btn btn-secondary bg-white text-emerald-600 border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/channel/user?userId=@(item.UserId)&username=@(item.UserName)">
                                                        <i class="fas fa-plus-circle mr-1"></i> Thêm kênh
                                                    </a>
                                                    <a class="btn btn-secondary bg-white text-indigo-600 border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/bot/user?userId=@(item.UserId)&username=@(item.UserName)">
                                                        <i class="fas fa-robot mr-1"></i> DS BOT
                                                    </a>
                                                    <button class="btn btn-secondary bg-white text-rose-500 border border-slate-200 btnCancelChannel" style="font-size:11px; padding:4px 8px;" data-id="@item.UserId">
                                                        <i class="fas fa-times-circle mr-1"></i> Hủy
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="modal fade" role="dialog" id="addUserModal">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content elevated-card border-0">
            <form method="post" id="formAddUsertoChannel" action="/admin/Channel/addUser">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title font-weight-bold text-brand h5">Thêm user cho kênh <span class="text-rose-500">@ViewBag.ChannelName</span></h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body py-4">
                    <div class="form-group mb-4">
                        <label class="font-weight-600 text-slate-700">Chọn user <span class="text-rose-500 font-normal ml-1">(Nếu user đã thêm thì sẽ xóa user ra khỏi kênh)</span></label>
                        <div class="mt-2">
                            <input name="channelId" type="hidden" value="@ViewBag.ChannelId" />
                            <input name="channelName" type="hidden" value="@ViewBag.ChannelName" />
                            <select name="userId" class="form-control select2 w-100 border-slate-200 shadow-sm" style="border-radius: 8px;" required>
                                <option>--Chọn user--</option>
                                @foreach (var item in users)
                                {
                                    <option value="@item.Id">@item.UserName</option>
                                }
                            </select>
                            <span class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary bg-slate-100 text-slate-700 border-0 shadow-none px-4" data-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm shadow-brand/30">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" tabindex="-1" role="dialog" id="deleteChannelOfUserModal">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content elevated-card border-0">
            <form method="post" id="formDeleteChannel" action="/admin/Channel/addUser">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title font-weight-bold text-rose-600 h5">Xóa kênh của người dùng</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body py-4">
                    <p class="text-slate-600 mb-0">Bạn có chắc chắn muốn xóa kênh <span class="text-rose-600 font-weight-bold">@ViewBag.ChannelName</span> của người dùng này không?</p>
                    <input class="form-control" name="userId" type="hidden" />
                    <input class="form-control" name="channelId" type="hidden" value="@ViewBag.ChannelId" />
                    <input class="form-control" name="channelName" type="hidden" value="@ViewBag.ChannelName" />
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary bg-slate-100 text-slate-700 border-0 shadow-none px-4" data-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-danger px-4 shadow-sm shadow-rose-500/30">Xóa Kênh</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#tableUserOfChannel").DataTable({});
            $('body').on('click', '.btnAddUser', function () {
                $('#addUserModal').modal('show');
            });
            $('body').on('click', '.btnCancelChannel', function () {
                let userId = $(this).attr('data-id');
                $('#deleteChannelOfUserModal').modal('show');
                $('#formDeleteChannel input[name="userId"]').val(userId);
            })
        });

    </script>
    <script>

    </script>
}

