@using BaseSource.ViewModels.ChannelAdmin;
@model List<ChannelAdminDto>
@{

    ViewData["Title"] = $"Danh sách Kênh của {ViewBag.BotName}";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var index = 1;
}
<section class="section">
    <div class="section-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <h1 class="mb-2">@ViewData["Title"]</h1>
        <div class="section-header-breadcrumb m-0">
            <div class="breadcrumb-item active"><a href="#">Hệ thống</a></div>
            <div class="breadcrumb-item"><a href="#">Danh sách</a></div>
            <div class="breadcrumb-item">Danh sách Kênh</div>
        </div>
    </div>

    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-header border-bottom-0 pb-0 d-flex justify-content-between align-items-center">
                        <h4 class="text-brand">Danh sách Kênh</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="tableChannels">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>Action</th>
                                        <th>Avatar</th>
                                        <th>Kênh</th>
                                        <th>Link kênh</th>
                                        <th>Gmail</th>
                                        <th>BotName</th>
                                        <th>Group</th>
                                        <th>Status</th>
                                        <th>Ngày tạo</th>
                                        <th>TotalUser</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>
                                                <div style="display: flex; flex-direction: column; gap: 4px; min-width: 100px;">
                                                    <a class="btn btn-secondary bg-white text-emerald-600 border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/channel/users?channelId=@(item.Id)&channelName=@(item.ChannelName)">
                                                        <i class="fas fa-users mr-1"></i> DS User
                                                    </a>
                                                    <button class="btn btn-secondary bg-white text-amber-500 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="updateChannel('@item.Id')">
                                                        <i class="fas fa-sync-alt mr-1"></i> Cập nhật
                                                    </button>
                                                    <button class="btn btn-secondary bg-white text-rose-500 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="deleteChannel('@item.Id')">
                                                        <i class="fas fa-trash-alt mr-1"></i> Xóa
                                                    </button>
                                                </div>
                                            </td>
                                            <td><img width="35" height="35" src="@item.Avatar" /></td>
                                            <td>@item.ChannelName</td>
                                            <td><a href="https://www.youtube.com/channel/@item.ChannelYTId">@item.ChannelYTId</a></td>
                                            <td>@item.ChannelGmail</td>
                                            <td>@item.BotName</td>
                                            <td>@item.Group</td>
                                            <td>
                                                @switch (item.Status)
                                                {

                                                    case ManagerBOTStatus.Connected:
                                                        <span class="badge badge-success">Connected</span>
                                                        break;
                                                    case ManagerBOTStatus.Disconnected:
                                                        <span class="badge badge-success">Disconnected</span>
                                                        break;
                                                }
                                            </td>
                                            <td>@item.CreatedTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                            <td> <span class="badge badge-primary">@item.TotalUser</span></td>

                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#tableChannels").DataTable({});
        });
        function updateChannel(channelId) {
            $.ajax({
                type: "POST",
                url: "/admin/channel/UpdateProfile",
                data: { id: channelId },
                success: function (response) {
                    location.reload();
                }
            });
        }
        function deleteChannel(id) {
            $.ajax({
                type: "POST",
                url: "/admin/channel/DeleteAjax",
                data: { id: id },
                success: function (response) {
                    location.reload();
                }
            });
        }
    </script>
}

