@using BaseSource.ViewModels.ChannelAdmin;
@model List<ChannelAdminDto>
@{

    ViewData["Title"] = $"Thêm kênh cho người dùng {ViewBag.UserName}";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var index = 1;
    var userId = ViewBag.UserId as string;
}
<section class="section">
    <div class="section-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <h1 class="mb-2">@ViewData["Title"]</h1>
        <div class="section-header-breadcrumb m-0">
            <div class="breadcrumb-item active"><a href="#">Hệ thống</a></div>
            <div class="breadcrumb-item"><a href="#">Danh sách Kênh</a></div>
            <div class="breadcrumb-item">Cấp quyền</div>
        </div>
    </div>

    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-header border-bottom-0 pb-0 d-flex justify-content-between align-items-center">
                        <h4 class="text-brand">Danh sách quyền Kênh</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="tableChannels">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>Avatar</th>
                                        <th>Kênh</th>
                                        <th>Link</th>
                                        <th>Gmail</th>
                                        <th>BotName</th>
                                        <th>Group</th>
                                        <th>Status</th>
                                        <th>Ngày tạo</th>
                                        <th>TotalUser</th>
                                        <th>Sử dụng</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td><img width="35" height="35" src="@item.Avatar" /></td>
                                            <td>@item.ChannelName</td>
                                            <td><a href="https://www.youtube.com/channel/@item.ChannelYTId">@item.ChannelYTId</a></td>
                                            <td>@item.ChannelGmail</td>
                                            <td>@item.BotName</td>
                                            <td>@item.Group</td>
                                            <td>
                                                @switch (item.Status)
                                                {

                                                    case ManagerBOTStatus.Connected:
                                                        <span class="badge badge-success">Connected</span>
                                                        break;
                                                    case ManagerBOTStatus.Disconnected:
                                                        <span class="badge badge-success">Disconnected</span>
                                                        break;
                                                }
                                            </td>
                                            <td>@item.CreatedTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                            <td> <span class="badge badge-primary">@item.TotalUser</span></td>
                                            <td>
                                                <div style="display: flex; flex-direction: column; gap: 4px; min-width: 80px;">
                                                    @if (item.IsUsed)
                                                    {
                                                        <button class="btn btn-secondary bg-white text-rose-500 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="cancelChannel('@item.Id')">
                                                            <i class="fas fa-times-circle mr-1"></i> Dừng
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-secondary bg-white text-emerald-600 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="addChannel('@item.Id')">
                                                            <i class="fas fa-check-circle mr-1"></i> Thêm
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                <div style="display: flex; flex-direction: column; gap: 4px; min-width: 100px;">
                                                    <a class="btn btn-secondary bg-white text-brand border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/channel/users?channelId=@(item.Id)&channelName=@(item.ChannelName)">
                                                        <i class="fas fa-users mr-1"></i> DS User
                                                    </a>
                                                    <button class="btn btn-secondary bg-white text-amber-500 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="updateChannel('@item.Id')">
                                                        <i class="fas fa-sync-alt mr-1"></i> Cập nhật
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="modal fade" tabindex="-1" role="dialog" id="addChannelModal">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content elevated-card border-0">
            <form method="post" id="formAddChannel" action="/admin/channel/UpdateUserChannel">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title font-weight-bold text-brand h5">Thêm Kênh cho người dùng</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body py-4">
                    <p class="text-slate-600 mb-0">Bạn có chắc chắn muốn <span class="text-emerald-600 font-weight-bold">cấp quyền truy cập</span> kênh này cho người dùng?</p>
                    <input class="form-control" value="@userId" name="userId" type="hidden" />
                    <input class="form-control" name="channelId" type="hidden" />
                    <input class="form-control" value="@ViewBag.UserName" name="username" type="hidden" />
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary bg-slate-100 text-slate-700 border-0 shadow-none px-4" data-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm shadow-brand/30">Xác nhận Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" tabindex="-1" role="dialog" id="canncelChannelModal">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content elevated-card border-0">
            <form method="post" id="formCancelChannel" action="/admin/channel/UpdateUserChannel">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title font-weight-bold text-rose-600 h5">Hủy Kênh của người dùng</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body py-4">
                    <p class="text-slate-600 mb-0">Bạn có chắc chắn muốn <span class="text-rose-600 font-weight-bold">thu hồi quyền truy cập</span> kênh này của người dùng?</p>
                    <input class="form-control" value="@userId" name="userId" type="hidden" />
                    <input class="form-control" name="channelId" type="hidden" />
                    <input class="form-control" value="@ViewBag.UserName" name="username" type="hidden" />
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary bg-slate-100 text-slate-700 border-0 shadow-none px-4" data-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-danger px-4 shadow-sm shadow-rose-500/30">Xác nhận Thu hồi</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#tableChannels").DataTable({});
        });
        function addChannel(channelId) {
            $('#addChannelModal').modal('show');
            $('#formAddChannel input[name="channelId"]').val(channelId);
        }
        function cancelChannel(channelId) {
            $('#canncelChannelModal').modal('show');
            $('#formCancelChannel input[name="channelId"]').val(channelId);
        }
        function updateChannel(channelId) {
            $.ajax({
                type: "POST",
                url: "/admin/channel/UpdateProfile",
                data: { id: channelId },
                success: function (response) {
                    location.reload();
                }
            });
        }

    </script>
}

