@using BaseSource.SharedSignalrData.Enums;
@using BaseSource.ViewModels.RenderAdmin;
@using BaseSource.ViewModels.Report;
@model List<RenderAdminInfoDto>
@{

    ViewData["Title"] = $"Danh sách Render của {ViewBag.ChannelName}";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var report = ViewBag.Report as ReportDto;
    var index = 1;
    var channelName = ViewBag.ChannelName;
}
<section class="section">
    <div class="section-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <h1 class="mb-2">@ViewData["Title"]</h1>
        <div class="section-header-breadcrumb m-0">
            <div class="breadcrumb-item active"><a href="#">Hệ thống</a></div>
            <div class="breadcrumb-item"><a href="#">Render</a></div>
            <div class="breadcrumb-item">Kênh</div>
        </div>
    </div>

    <div class="section-body">
        <div class="row mb-4">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-stats-title border-bottom" style="border-color: #f1f5f9 !important;">
                        Thống kê hệ thống Render theo Kênh
                    </div>
                    <div class="card-stats-items">
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalChannel</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-success">Tổng Số Kênh</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#10b981;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@(report.TotalBotConnected)/@(report.TotalBot)</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-primary">BOT Đang Chạy</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#6366f1;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalUser</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-info">Tổng User</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#0ea5e9;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalRenderInRun</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-primary" style="background:rgba(93,103,223,0.12);color:#5d67df;">Đang Render</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#5d67df;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalRenderUpload</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-info" style="background:rgba(14,165,233,0.12);color:#0284c7;">Đang Upload</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#0284c7;"></div>
                        </div>
                        <div class="card-stats-item text-center border-0">
                            <div class="card-stats-item-count">@report.TotalRenderPending</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-warning">Job Đang Chờ</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#f59e0b;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-header border-bottom-0 pb-0 d-flex justify-content-between align-items-center">
                        <h4 class="text-brand">Danh sách Job theo Kênh</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="tableRenders">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>User</th>
                                        <th class="text-center">
                                            Ngày tạo
                                        </th>
                                        <th>VideoName</th>
                                        <th>BotName</th>
                                        <th>Avatar</th>
                                        <th>Kênh</th>
                                        <th>Link Kênh</th>
                                        <th>Link video</th>
                                        <th>Time Render</th>
                                        <th>Start Download</th>
                                        <th>Start Upload</th>
                                        <th>Complete Upload</th>
                                        <th>Status</th>
                                        <th>Queueing</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>@item.UserName</td>
                                            <td>
                                                <span class="">@item.CreatedTime.ToString("dd/MM/yyyy HH:mm:ss")</span>
                                            </td>
                                            <td>@item.VideoName</td>
                                            <td>
                                                <span class="text-danger">@item.BotName</span>
                                            </td>
                                            <td><img width="35" height="35" src="@item.Avatar" /></td>
                                            <td>
                                                <span class="">@item.ChannelName</span>
                                            </td>
                                            <td><a href="https://www.youtube.com/channel/@item.ChannelYTId">@item.ChannelYTId</a></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.VideoLink))
                                                {
                                                    <a href="@item.VideoLink">@item.VideoLink</a>
                                                }

                                            </td>
                                            <td>@item.TimeRender</td>
                                            <td>@item.DownloadStartTime?.ToString("dd/MM/yyyy: HH:mm:ss")</td>
                                            <td>@item.UploadStartTime?.ToString("dd/MM/yyyy: HH:mm:ss")</td>
                                            <td>@item.UploadTimeCompleted?.ToString("dd/MM/yyyy: HH:mm:ss")</td>
                                            <td>
                                                @switch (item.Status)
                                                {
                                                    case WorkStatus.Pending:
                                                        <span class="badge badge-warning">Pending</span>
                                                        break;
                                                    case WorkStatus.Schedule:
                                                        <span class="badge badge-warning">Schedule(@item.ScheduleTime?.ToString("dd/MM/yyyy HH:mm:ss"))</span>
                                                        break;

                                                    case WorkStatus.Queueing:
                                                        <span class="badge badge-warning">Queueing</span>
                                                        break;
                                                    case WorkStatus.Downloading:
                                                        <span class="badge badge-primary">Downloading(@(item.Pencent)%)</span>
                                                        break;
                                                    case WorkStatus.Rendering:
                                                        <span class="badge badge-primary">Rendering(@(item.Pencent)%) </span>
                                                        break;
                                                    case WorkStatus.Uploading:
                                                        <span class="badge badge-info">Uploading(@(item.Pencent)%)</span>
                                                        break;
                                                    case WorkStatus.Completed:
                                                        <span class="badge badge-success">Completed</span>
                                                        break;
                                                    case WorkStatus.Cancelled:
                                                        <span class="badge badge-danger">Cancelled</span>
                                                        break;
                                                    case WorkStatus.Error:
                                                        <span class="badge badge-danger">Error - (@item.ErrorMessage)</span>
                                                        break;

                                                }
                                            </td>
                                            <td>@item.Order</td>
                                            <td>
                                                <a class="btn btn-sm btn-primary" href="/admin/render/renderInfo?id=@item.Id">Chi tiết</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#tableRenders").DataTable({});
        });

    </script>
}

