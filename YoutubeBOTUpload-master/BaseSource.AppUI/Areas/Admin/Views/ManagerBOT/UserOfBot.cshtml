@using BaseSource.ViewModels.ManagerBOTAdmin;
@model List<UserManagerBotAdminInfoDto>
@{
    var botName = ViewBag.BotName;
    ViewData["Title"] = $"Danh sách Người dùng của ({botName})";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var index = 1;
}
<section class="section">
    <div class="section-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <h1 class="mb-2">@ViewData["Title"]</h1>
        <div class="section-header-breadcrumb m-0">
            <div class="breadcrumb-item active"><a href="#">Hệ thống</a></div>
            <div class="breadcrumb-item"><a href="#">Máy chủ</a></div>
            <div class="breadcrumb-item">Người dùng của BOT</div>
        </div>
    </div>

    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-header border-bottom-0 pb-0 d-flex justify-content-between align-items-center">
                        <h4 class="text-brand">Danh sách Admin được phân quyền</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="tableUserOfBot">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>Người dùng</th>
                                       @* <th>Mật khẩu</th>*@
                                        <th>Số kênh</th>
                                        <th>Số Bot</th>
                                       
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>@item.UserName</td>
                                           @* <td>@item.Password</td>*@
                                            <td><span class="badge badge-primary">@item.TotalChannel</span></td>
                                            <td><span class="badge badge-primary">@item.TotalBot</span></td>
                                            <td>
                                                <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                                    <a class="btn btn-secondary bg-white text-brand border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/channel/user?userId=@(item.UserId)&username=@(item.UserName)">
                                                        <i class="fas fa-satellite-dish mr-1"></i> Thêm kênh
                                                    </a>
                                                    <a class="btn btn-secondary bg-white text-emerald-600 border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/bot/user?userId=@(item.UserId)&username=@(item.UserName)">
                                                        <i class="fas fa-server mr-1"></i> DS BOT
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#tableUserOfBot").DataTable({});
        });
    </script>
}

