@using BaseSource.ViewModels.ManagerBOT;
@using BaseSource.ViewModels.Report;
@model List<ManagerBotInfoDto>
@{
    var userName = ViewBag.UserName;
    ViewData["Title"] = $"Danh sách BOT";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var index = 1;
    var report = ViewBag.Report as ReportDto;
    var managers = ViewBag.Managers as List<UserAdminInfoDto>;
    var managerChoose = ViewBag.ManagerChooses as List<string>;
}
<section class="section">
    <div class="section-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        @if (User.IsInRole("Admin"))
        {
            <div>
                <h1 class="mb-2">Quản lý BOT</h1>
                <div class="d-flex align-items-center gap-2">
                    <div style="min-width: 250px;">
                        <select class="form-control select2" id="managerChoose" multiple data-placeholder="Lọc theo Manager...">
                            @foreach (var item in managers)
                            {
                                <option value="@item.Id" selected="@(managerChoose.Any(x=>x==item.Id))">@item.UserName</option>
                            }
                        </select>
                    </div>
                    <button class="btn btn-primary d-flex align-items-center gap-2" onclick="reloadPage()">
                        <i class="fas fa-filter"></i> Lọc
                    </button>
                </div>
            </div>
        }
        else
        {
             <h1>@ViewData["Title"]</h1>
        }
        
        <div class="section-header-breadcrumb m-0">
            <div class="breadcrumb-item active"><a href="#">Hệ thống</a></div>
            <div class="breadcrumb-item"><a href="#">Máy chủ</a></div>
            <div class="breadcrumb-item">Quản lý BOT</div>
        </div>
    </div>

    <div class="section-body">

        <div class="row mb-4">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-stats-title border-bottom" style="border-color: #f1f5f9 !important;">
                        Thống kê hệ thống máy chủ / BOT
                    </div>
                    <div class="card-stats-items">
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalChannel</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-success">Tổng Số Kênh</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#10b981;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@(report.TotalBotConnected)/@(report.TotalBot)</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-primary">BOT Đang Chạy</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#6366f1;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalUser</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-info">Tổng User</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#0ea5e9;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalRenderInRun</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-primary" style="background:rgba(93,103,223,0.12);color:#5d67df;">Đang Render</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#5d67df;"></div>
                        </div>
                        <div class="card-stats-item text-center">
                            <div class="card-stats-item-count">@report.TotalRenderUpload</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-info" style="background:rgba(14,165,233,0.12);color:#0284c7;">Đang Upload</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#0284c7;"></div>
                        </div>
                        <div class="card-stats-item text-center border-0">
                            <div class="card-stats-item-count">@report.TotalRenderPending</div>
                            <div class="card-stats-item-label">
                                <span class="badge badge-warning">Job Đang Chờ</span>
                            </div>
                            <div class="mt-3 mx-auto" style="height:4px; width:32px; border-radius:4px; background-color:#f59e0b;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="elevated-card p-0">
                    <div class="card-header border-bottom-0 pb-0 d-flex justify-content-between align-items-center">
                        <h4 class="text-brand">Danh sách Server BOT</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="tableBots">
                                <thead>
                                    <tr>
                                        <th>STT</th>
                                        <th>BotID</th>
                                        <th>Action</th>
                                        <th>Manager</th>
                                        <th>BotName</th>

                                        <th>Group</th>
                                        <th>Status</th>
                                        <th>Ngày tạo</th>
                                        <th>Số kênh</th>
                                        <th>Số User</th>
                                        <th>Luồng</th>
                                        <th>Space</th>
                                        <th>Bandwidth</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>@item.BotId</td>
                                            <td>
                                                <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                                    <a class="btn btn-secondary bg-white text-brand border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/channel/bot?botId=@(item.Id)&botName=@(item.Name)">
                                                        <i class="fas fa-link mr-1"></i> DS Kênh
                                                    </a>
                                                    <a class="btn btn-secondary bg-white text-emerald-600 border border-slate-200" style="font-size:11px; padding:4px 8px;" href="/admin/bot/userofbot?botId=@(item.Id)&botName=@(item.Name)">
                                                        <i class="fas fa-users mr-1"></i> DS User
                                                    </a>
                                                    <button class="btn btn-secondary bg-white text-amber-500 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="updateBot('@item.Id','@item.Name','@item.Group','@item.UserIdManager')">
                                                        <i class="fas fa-edit mr-1"></i> Sửa
                                                    </button>
                                                    <button class="btn btn-secondary bg-white text-rose-500 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="deleteBot('@item.Id')">
                                                        <i class="fas fa-trash-alt mr-1"></i> Xóa
                                                    </button>
                                                    <button class="btn btn-secondary bg-white text-sky-500 border border-slate-200" style="font-size:11px; padding:4px 8px;" onclick="updateThreadBot('@item.Id','@item.NumberOfThreads')">
                                                        <i class="fas fa-microchip mr-1"></i> Luồng
                                                    </button>
                                                </div>
                                            </td>
                                            <td>@(item.UserManager)</td>
                                            <td>@item.Name</td>
                                            <td>@item.Group </td>

                                            <td>
                                                @if (item.Status == ManagerBOTStatus.Connected)
                                                {
                                                    <span class="badge badge-success">Connected</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Disconnected</span>
                                                }
                                            </td>
                                            <td>@item.CreatedTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                            <td><span class="badge badge-primary">@item.TotalChannel</span></td>
                                            <td><span class="badge badge-primary">@item.TotalUser</span></td>
                                            <td><span class="badge badge-info">@(item.NumberOfThreadsInRun)/@(item.NumberOfThreads)</span></td>
                                            <td><span class="badge badge-success">@((item.UsageDisk / 1024.0 / 1024 / 1024).ToString("N2"))GB / @((item.SpaceDisk / 1024.0 / 1024 / 1024).ToString("N2"))GB</span> </td>
                                            <td>@item.Bandwidth.ToString("n2") KB/s</td>

                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="modal fade" role="dialog" id="updateBotModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" id="formUpdateBOT" action="/admin/bot/update">
                <div class="modal-header">
                    <h5 class="modal-title">Cập nhật BOT</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-4">
                        <label class="">Tên BOT</label>
                        <div class="">
                            <input name="Name" placeholder="Nhập tên BOT" required class="form-control" />
                            <input name="Id" type="hidden" />
                            <span class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group mb-4">
                        <label class="">Group</label>
                        <div class="">
                            <input name="Group" placeholder="Nhập Group BOT" required class="form-control" />
                            <span class="text-danger"></span>
                        </div>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="form-group mb-4">
                            <label class="">Managers</label>
                            <div class="">
                                <select class="form-control select2" name="UserIdManager">
                                    <option value="">-- Chọn Manager --</option>
                                    @foreach (var item in managers)
                                    {
                                        <option value="@item.Id">@item.UserName</option>
                                    }
                                </select>


                            </div>
                        </div>
                    }

                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Cập nhật</button>

                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" role="dialog" id="deleteBotModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" id="formDeleteBot" action="/admin/managerbot/Delete">
                <div class="modal-header">
                    <h5 class="modal-title">Xóa Thông tin BOT?</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p class="text-danger">Sau khi xóa BOT sẽ xóa tất cả các Render, Kênh liên quan đến BOT. Bạn có muốn BOT này?</p>
                    <input class="form-control" name="Id" type="hidden" />
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-danger">Xác nhận</button>

                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" role="dialog" id="updateThreadBotModal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" id="formUpdateThreadBOT" action="/admin/bot/updateThread">
                <div class="modal-header">
                    <h5 class="modal-title">Cập nhật số luồng BOT</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-4">
                        <label class="">Nhập số luồng</label>
                        <div class="">
                            <input name="Thread" placeholder="Nhập số luồng" min="1" required class="form-control" />
                            <input name="Id" type="hidden" />
                            <span class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Cập nhật</button>

                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#tableBots").DataTable({});
        });
        function updateBot(id, name, group, manager) {
            $('#updateBotModal').modal('show');
            $('#formUpdateBOT input[name="Id"]').val(id);
            $('#formUpdateBOT input[name="Name"]').val(name);
            $('#formUpdateBOT input[name="Group"]').val(group);
            $('#formUpdateBOT select[name="UserIdManager"]').val(manager);
        }
        function deleteBot(id) {
            $('#deleteBotModal').modal('show');
            $('#formDeleteBot input[name="Id"]').val(id);
        }
        function updateThreadBot(id, thread) {
            $('#updateThreadBotModal').modal('show');
            $('#formUpdateThreadBOT input[name="Id"]').val(id);
            $('#formUpdateThreadBOT input[name="Thread"]').val(thread);
        }

    </script>
}

