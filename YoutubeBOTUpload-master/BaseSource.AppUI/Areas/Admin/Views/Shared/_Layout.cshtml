<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, shrink-to-fit=no" name="viewport">
    <title>Upload YouTube — Quản trị</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">

    <!-- Bootstrap 4 -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T" crossorigin="anonymous">

    <!-- FontAwesome -->
    <link href="~/admin-themes/assets/modules/fontawesome/css/all.min.css" rel="stylesheet" />

    <!-- DataTables -->
    <link href="~/admin-themes/assets/modules/datatables/dataTables.bootstrap4.min.css" rel="stylesheet" />
    <link href="~/admin-themes/assets/modules/datatables/select.bootstrap4.min.css" rel="stylesheet" />

    <!-- Select2 -->
    <link rel="stylesheet" href="~/admin-themes/assets/modules/select2/dist/css/select2.min.css">
    <link rel="stylesheet" href="~/admin-themes/assets/modules/jquery-selectric/selectric.css">

    <!-- Template CSS (Stisla base) -->
    <link href="~/admin-themes/assets/css/style.css" rel="stylesheet" />
    <link href="~/admin-themes/assets/css/components.css" rel="stylesheet" />

    <!-- ELEVATED ADMIN — Design System Override -->
    <link href="~/css/elevated-admin.css" rel="stylesheet" />

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="icon" type="image/x-icon" href="~/live-logo.png" asp-append-version="true" />
</head>

<body>
    <div id="app">
        <div class="main-wrapper">
            <div class="navbar-bg"></div>
            <nav class="navbar navbar-expand-lg main-navbar">
                <form class="form-inline mr-auto">
                    <ul class="navbar-nav mr-3">
                        <li><a href="#" data-toggle="sidebar" class="nav-link nav-link-lg"><i class="fas fa-bars"></i></a></li>
                    </ul>
                    <span style="font-family:'Be Vietnam Pro',sans-serif; font-weight:600; font-size:14px; color:#64748b; margin-left:8px;">
                        <i data-lucide="layout-dashboard" style="width:16px;height:16px;display:inline-block;vertical-align:middle;margin-right:6px;"></i>
                        Bảng điều khiển quản trị
                    </span>
                </form>
                <ul class="navbar-nav navbar-right">
                    <li class="dropdown">
                        <a href="#" data-toggle="dropdown" class="nav-link dropdown-toggle nav-link-lg nav-link-user">
                            <img alt="image" src="~/admin-themes/assets/img/avatar/avatar-1.png" class="rounded-circle mr-1">
                            @await Component.InvokeAsync("UserInfo")
                        </a>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a href="/account/profile" class="dropdown-item has-icon">
                                <i class="fas fa-user"></i> Cá nhân
                            </a>
                            <div class="dropdown-divider"></div>
                            <a href="/account/Logout" class="dropdown-item has-icon text-danger">
                                <i class="fas fa-sign-out-alt"></i> Đăng xuất
                            </a>
                        </div>
                    </li>
                </ul>
            </nav>

            <div class="main-sidebar">
                <aside id="sidebar-wrapper">
                    <div class="sidebar-brand">
                        <a href="/admin/user/index">
                            <span style="display:inline-flex;align-items:center;gap:8px;">
                                <span style="background:linear-gradient(135deg,#5d67df,#6366f1);color:#fff;width:32px;height:32px;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;">▶</span>
                                UploadYT
                            </span>
                        </a>
                    </div>
                    <div class="sidebar-brand sidebar-brand-sm">
                        <a href="/admin/user/index">▶</a>
                    </div>
                    <ul class="sidebar-menu">
                        <li class="menu-header" style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:#94a3b8;padding:16px 14px 6px;font-weight:600;">Quản lý</li>

                        <li><a class="nav-link" href="/admin/user/index"><i class="fas fa-users"></i> <span>Người dùng</span></a></li>
                        <li><a class="nav-link" href="/admin/ManagerBOT/index"><i class="fas fa-server"></i> <span>Danh sách BOT</span></a></li>
                        <li><a class="nav-link" href="/admin/channel/index"><i class="fas fa-link"></i> <span>Danh sách Kênh</span></a></li>
                        <li><a class="nav-link" href="/admin/render/index"><i class="fas fa-video"></i> <span>Danh sách Render</span></a></li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="menu-header" style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:#94a3b8;padding:20px 14px 6px;font-weight:600;">Phân quyền</li>
                            <li><a class="nav-link" href="/admin/user/manager"><i class="fas fa-user-shield"></i> <span>Danh sách Manager</span></a></li>
                            <li><a class="nav-link" href="/admin/user/admins"><i class="fas fa-crown"></i> <span>Danh sách Admin</span></a></li>
                        }

                        <li class="menu-header" style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:#94a3b8;padding:20px 14px 6px;font-weight:600;">Tài khoản</li>
                        <li><a class="nav-link" href="/account/profile"><i class="fas fa-user-cog"></i> <span>Cá nhân</span></a></li>
                    </ul>
                </aside>
            </div>

            <!-- Main Content -->
            <div class="main-content">
                @RenderBody()
            </div>

            <footer class="main-footer">
                <div class="footer-left">
                    © 2024 Upload YouTube <span style="color:#cbd5e1;margin:0 8px;">·</span> Powered by Deerflow
                </div>
            </footer>
        </div>
    </div>

    <!-- General JS Scripts -->
    <script src="~/admin-themes/assets/modules/jquery.min.js"></script>
    <script src="~/admin-themes/assets/modules/popper.js"></script>
    <script src="~/admin-themes/assets/modules/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/admin-themes/assets/modules/jquery.nicescroll.min.js"></script>
    <script src="~/admin-themes/assets/modules/moment.min.js"></script>
    <script src="~/admin-themes/assets/js/stisla.js"></script>

    <!-- JS Libraries -->
    <script src="~/admin-themes/assets/modules/datatables/datatables.min.js"></script>
    <script src="~/admin-themes/assets/modules/datatables/dataTables.bootstrap4.min.js"></script>
    <script src="~/admin-themes/assets/modules/datatables/dataTables.select.min.js"></script>
    <script src="~/admin-themes/assets/modules/select2/dist/js/select2.full.min.js"></script>
    <script src="~/admin-themes/assets/modules/jquery-selectric/jquery.selectric.min.js"></script>

    <!-- Template JS -->
    <script src="~/admin-themes/assets/js/scripts.js"></script>
    <script src="~/admin-themes/assets/js/custom.js"></script>
    <script src="~/admin-themes/assets/js/page/bootstrap-modal.js"></script>
    <script src="~/admin-themes/assets/js/page/modules-datatables.js"></script>

    <!-- Lucide Init -->
    <script>document.addEventListener('DOMContentLoaded', () => { if(window.lucide) lucide.createIcons(); });</script>

    <!-- Manager Session (unchanged) -->
    <script>
        $('body').on('change', '#managerChoose', function () {
            let val = $(this).val();
            $.ajax({
                type: "POST",
                url: "/admin/UpdateSession",
                data: { managers: val },
                success: function (response) { }
            });
        })
        function reloadPage() {
            location.reload();
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
