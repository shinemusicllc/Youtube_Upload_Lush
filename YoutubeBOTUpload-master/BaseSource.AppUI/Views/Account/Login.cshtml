@using BaseSource.ViewModels.User
@model LoginRequestVm
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập — Upload YouTube</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50:'#eef2ff',100:'#e0e7ff',200:'#c7d2fe',300:'#a5b4fc',
                            400:'#818cf8',500:'#6b74f0',600:'#5d67df',700:'#4b56c9',800:'#3730a3',900:'#312e81'
                        },
                        surface: {
                            900:'#0f1729',800:'#131d35',700:'#1a2744',600:'#213154'
                        }
                    },
                    fontFamily: {
                        sans:['Inter','sans-serif'],
                        display:['Be Vietnam Pro','sans-serif'],
                    }
                }
            }
        }
    </script>
    
    <link rel="icon" type="image/x-icon" href="~/live-logo.png" />
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        *{-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}

        body {
            background: #0f1729;
            min-height: 100vh;
            overflow: hidden;
            position: relative;
        }

        /* ── Grid canvas background ── */
        .grid-canvas {
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background-image:
                linear-gradient(rgba(148,163,184,0.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(148,163,184,0.06) 1px, transparent 1px);
            background-size: 60px 60px;
        }

        /* ── Floating geometric shapes ── */
        .geo-shapes {
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            overflow: hidden;
        }
        .geo-rect {
            position: absolute;
            border-radius: 6px;
            transition: opacity 0.3s ease;
        }
        /* Large center block */
        .geo-rect.r1 {
            width: 340px; height: 260px;
            bottom: 10%; left: 50%; transform: translateX(-40%);
            background: rgba(30,58,95,0.45);
            border: 1px solid rgba(100,160,220,0.08);
            border-radius: 14px;
        }
        /* Teal accent block */
        .geo-rect.r2 {
            width: 140px; height: 120px;
            top: 18%; right: 28%;
            background: linear-gradient(135deg, rgba(56,189,248,0.18) 0%, rgba(14,165,233,0.12) 100%);
            border: 1px solid rgba(56,189,248,0.15);
        }
        /* Dark medium block */
        .geo-rect.r3 {
            width: 90px; height: 80px;
            top: 25%; left: 30%;
            background: rgba(51,65,85,0.5);
            border: 1px solid rgba(100,116,139,0.12);
        }
        /* Small bright accent */
        .geo-rect.r4 {
            width: 60px; height: 55px;
            top: 12%; left: 44%;
            background: linear-gradient(135deg, rgba(6,182,212,0.3) 0%, rgba(59,130,246,0.25) 100%);
            border: 1px solid rgba(6,182,212,0.2);
        }
        /* Tiny block top-left */
        .geo-rect.r5 {
            width: 40px; height: 35px;
            top: 30%; left: 15%;
            background: rgba(148,163,184,0.08);
            border: 1px solid rgba(148,163,184,0.1);
        }
        /* Bottom-right medium */
        .geo-rect.r6 {
            width: 200px; height: 50px;
            bottom: 18%; left: 48%;
            background: rgba(30,41,59,0.5);
            border: 1px solid rgba(100,116,139,0.08);
            border-radius: 8px;
        }
        /* Right-side small accent */
        .geo-rect.r7 {
            width: 50px; height: 45px;
            top: 38%; right: 18%;
            background: rgba(148,163,184,0.06);
            border: 1px solid rgba(148,163,184,0.1);
        }
        /* Large ghosted frame */
        .geo-rect.r8 {
            width: 420px; height: 320px;
            top: 15%; left: 20%;
            background: transparent;
            border: 1px solid rgba(148,163,184,0.06);
            border-radius: 12px;
        }
        /* Inner highlight block */
        .geo-rect.r9 {
            width: 120px; height: 100px;
            top: 35%; left: 42%;
            background: rgba(30,58,95,0.35);
            border: 1px solid rgba(56,189,248,0.1);
            box-shadow: inset 0 0 20px rgba(56,189,248,0.03);
        }
        /* Top-right bright square */
        .geo-rect.r10 {
            width: 70px; height: 65px;
            top: 15%; right: 22%;
            background: linear-gradient(135deg, rgba(14,165,233,0.25) 0%, rgba(56,189,248,0.15) 100%);
            border: 1px solid rgba(56,189,248,0.18);
        }

        /* ── Login card ── */
        .login-card {
            background: rgba(19,29,53,0.75);
            backdrop-filter: blur(32px);
            -webkit-backdrop-filter: blur(32px);
            border: 1px solid rgba(148,163,184,0.1);
            box-shadow:
                0 4px 16px rgba(0,0,0,0.2),
                0 24px 48px rgba(0,0,0,0.15),
                inset 0 1px 0 rgba(255,255,255,0.04);
            border-radius: 20px;
            overflow: hidden;
        }

        /* ── Brand panel (left) ── */
        .brand-panel {
            background: linear-gradient(160deg, #1a2744 0%, #131d35 60%, #0f1729 100%);
            position: relative;
            overflow: hidden;
        }
        .brand-panel::before {
            content: '';
            position: absolute; inset: 0;
            background:
                radial-gradient(circle at 30% 70%, rgba(93,103,223,0.08) 0%, transparent 50%),
                radial-gradient(circle at 70% 30%, rgba(56,189,248,0.06) 0%, transparent 50%);
        }

        /* Brand panel grid */
        .brand-grid {
            position: absolute; inset: 0;
            background-image:
                linear-gradient(rgba(148,163,184,0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(148,163,184,0.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        /* Brand floating rects */
        .brand-rect {
            position: absolute;
            border-radius: 4px;
        }
        .brand-rect.br1 {
            width: 80px; height: 70px; top: 20%; right: 10%;
            background: rgba(93,103,223,0.12);
            border: 1px solid rgba(93,103,223,0.15);
        }
        .brand-rect.br2 {
            width: 50px; height: 50px; bottom: 30%; left: 8%;
            background: rgba(56,189,248,0.08);
            border: 1px solid rgba(56,189,248,0.1);
        }
        .brand-rect.br3 {
            width: 110px; height: 35px; bottom: 15%; right: 15%;
            background: rgba(148,163,184,0.04);
            border: 1px solid rgba(148,163,184,0.06);
            border-radius: 6px;
        }

        /* ── Form panel (right) ── */
        .form-panel {
            background: linear-gradient(180deg, rgba(255,255,255,0.97) 0%, rgba(248,250,252,0.98) 100%);
        }

        /* ── Input styles ── */
        .form-input {
            width: 100%;
            padding: 13px 14px 13px 44px;
            background: #f1f5f9;
            border: 1.5px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            color: #0f172a;
            outline: none;
            transition: all 0.2s ease;
        }
        .form-input::placeholder { color: #94a3b8; font-weight: 400; }
        .form-input:focus {
            background: white;
            border-color: #5d67df;
            box-shadow: 0 0 0 3px rgba(93,103,223,0.12);
        }

        /* ── CTA ── */
        .btn-login {
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            background: linear-gradient(135deg, #5d67df 0%, #4f46e5 100%);
            color: white;
            font-weight: 700;
            font-size: 14px;
            letter-spacing: 0.02em;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.25s ease;
            box-shadow: 0 4px 14px rgba(93,103,223,0.4);
        }
        .btn-login:hover {
            box-shadow: 0 8px 24px rgba(93,103,223,0.5);
            transform: translateY(-1px);
        }
        .btn-login:active { transform: translateY(1px); }

        /* ── Feature chip ── */
        .feature-chip {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 6px 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px;
            color: rgba(255,255,255,0.7);
            font-size: 11px; font-weight: 600;
        }

        /* ── Error ── */
        .error-banner {
            background: #fff1f2; border: 1px solid #fecdd3;
            border-radius: 12px; padding: 12px 14px;
            display: flex; align-items: flex-start; gap: 10px;
        }
    </style>
</head>
<body class="font-sans antialiased">

    <!-- Background layers -->
    <div class="grid-canvas"></div>
    <div class="geo-shapes">
        <div class="geo-rect r8"></div>
        <div class="geo-rect r1"></div>
        <div class="geo-rect r9"></div>
        <div class="geo-rect r3"></div>
        <div class="geo-rect r4"></div>
        <div class="geo-rect r2"></div>
        <div class="geo-rect r10"></div>
        <div class="geo-rect r5"></div>
        <div class="geo-rect r6"></div>
        <div class="geo-rect r7"></div>
    </div>

    <div class="relative z-10 w-full min-h-screen flex items-center justify-center px-4 py-12">
        <div class="login-card w-full max-w-[920px] flex flex-col md:flex-row">

            <!-- ═══════ LEFT: Brand Panel ═══════ -->
            <div class="brand-panel w-full md:w-[400px] shrink-0 p-10 lg:p-12 flex flex-col justify-between text-white">
                <div class="brand-grid"></div>
                <div class="brand-rect br1"></div>
                <div class="brand-rect br2"></div>
                <div class="brand-rect br3"></div>

                <div class="relative z-10">
                    <!-- Logo: Orange from sidebar -->
                    <div class="flex items-center gap-3 mb-14">
                        <div class="w-11 h-11 text-[#ff5528] flex items-center justify-center shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="w-11 h-11" aria-hidden="true">
                                <g fill="currentColor">
                                    <path d="M58 22c-7 0-12 5-12 12v116c0 56 45 102 101 102h54c7 0 12-5 12-12s-5-12-12-12h-54c-43 0-77-35-77-78V34c0-7-5-12-12-12z"/>
                                    <path d="M106 66c0-5 3-9 8-11 5-2 10-1 14 3l34 35 34-35c3-4 9-5 14-3 5 2 8 6 8 11v109c0 7-5 12-12 12s-12-5-12-12V95l-24 24c-5 5-12 5-17 0l-24-24v80c0 7-5 12-12 12s-12-5-12-12V66z"/>
                                    <rect x="181" y="119" width="14" height="78" rx="7"/>
                                    <circle cx="188" cy="205" r="28"/>
                                </g>
                            </svg>
                        </div>
                        <div>
                            <span class="font-display font-bold text-[17px] tracking-tight leading-none text-white">Upload YouTube</span>
                            <p class="text-[10px] text-slate-400 mt-1 font-medium tracking-wide uppercase">Control Plane</p>
                        </div>
                    </div>

                    <!-- Headline -->
                    <h1 class="font-display font-extrabold text-[30px] leading-[1.15] mb-4 tracking-tight text-white">
                        Chào mừng<br>trở lại
                        <span class="inline-block w-2 h-2 rounded-full bg-emerald-400 ml-1 align-top mt-1"></span>
                    </h1>
                    <p class="text-slate-400 text-[13px] leading-relaxed font-medium mb-10 max-w-[280px]">
                        Hệ thống điều phối render, quản lý upload video tự động lên đa nền tảng.
                    </p>

                    <!-- Feature chips -->
                    <div class="flex flex-wrap gap-2">
                        <span class="feature-chip">
                            <i data-lucide="zap" class="w-3 h-3 text-amber-400"></i> Auto Render
                        </span>
                        <span class="feature-chip">
                            <i data-lucide="cloud-upload" class="w-3 h-3 text-sky-400"></i> Upload
                        </span>
                        <span class="feature-chip">
                            <i data-lucide="shield-check" class="w-3 h-3 text-emerald-400"></i> OAuth
                        </span>
                    </div>
                </div>

                <!-- Bottom -->
                <div class="relative z-10 mt-12">
                    <div class="flex items-center gap-2.5">
                        <div class="w-2 h-2 rounded-full bg-emerald-400 shadow-lg shadow-emerald-400/40 animate-pulse"></div>
                        <span class="text-[11px] font-semibold text-slate-500 tracking-wide">System Online · Admin Dashboard</span>
                    </div>
                </div>
            </div>

            <!-- ═══════ RIGHT: Login Form ═══════ -->
            <div class="form-panel flex-1 p-10 lg:p-14 flex flex-col justify-center">
                <div class="mb-10">
                    <p class="text-[#ff5528] text-[11px] font-bold tracking-widest uppercase mb-3">ĐĂNG NHẬP QUẢN TRỊ</p>
                    <h2 class="font-display font-bold text-[26px] text-slate-900 mb-2 tracking-tight">Truy cập hệ thống</h2>
                    <p class="text-slate-500 text-[13px] font-medium leading-relaxed">Nhập thông tin tài khoản admin hoặc manager để tiếp tục.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="error-banner mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-rose-500 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        <div class="text-sm font-medium text-rose-700">
                            <span asp-validation-for="UserName" class="block"></span>
                            <span asp-validation-for="Password" class="block"></span>
                        </div>
                    </div>
                }

                <form id="register_form" method="POST" action="/account/login">
                    <input type="hidden" name="_token" value="DKgv8uzdV2sece2ehFRl6vYA4fX8p67L1kbQ2QBi" />
                    <div class="space-y-5">
                        <div>
                            <label for="UserName" class="block text-[12px] font-semibold text-slate-600 mb-2 tracking-wide">Tên đăng nhập</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                    <i data-lucide="user" class="w-[18px] h-[18px] text-slate-400"></i>
                                </div>
                                <input id="UserName" type="text" name="UserName" value="@Model.UserName" required
                                       class="form-input" placeholder="Nhập tài khoản" />
                            </div>
                        </div>
                        <div>
                            <label for="Password" class="block text-[12px] font-semibold text-slate-600 mb-2 tracking-wide">Mật khẩu</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                    <i data-lucide="lock" class="w-[18px] h-[18px] text-slate-400"></i>
                                </div>
                                <input id="Password" type="password" name="Password" value="@Model.Password" required
                                       class="form-input" placeholder="Nhập mật khẩu" />
                                <button type="button" onclick="togglePassword()" class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-slate-400 hover:text-slate-600 transition-colors">
                                    <i data-lucide="eye" id="eyeIcon" class="w-[18px] h-[18px]"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn-login mt-8">
                        <span>Đăng nhập hệ thống</span>
                        <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </button>
                </form>

                <div class="mt-10 pt-6 border-t border-slate-100 text-center">
                    <p class="text-[11px] text-slate-400 font-medium">© 2024 Upload YouTube. Designed for productivity.</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        function togglePassword() {
            const p = document.getElementById('Password');
            const e = document.getElementById('eyeIcon');
            if (p.type === 'password') { p.type = 'text'; e.setAttribute('data-lucide','eye-off'); }
            else { p.type = 'password'; e.setAttribute('data-lucide','eye'); }
            lucide.createIcons();
        }
    </script>
</body>
</html>
