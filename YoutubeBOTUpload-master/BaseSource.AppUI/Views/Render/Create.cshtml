        $(document).ready(function () {
            $("#TimeRender").on("input", function () {
                var timeSpanInput = $(this).val();

                if (!isValidTimeSpanFormat(timeSpanInput)) {

                    $('span[data-valmsg-for="TimeRender"]').html('Định dạng thời gian không hợp lệ');
                    // Thực hiện xử lý lỗi hoặc thông báo cho người dùng
                    // alert("Định dạng thời gian không hợp lệ");
                } else {
                    $('span[data-valmsg-for="TimeRender"]').html('');
                }
            });

            function isValidTimeSpanFormat(timeSpanInput) {
                // Kiểm tra định dạng chuỗi thời gian
                if (!/^\d{1,4}:\d{1,2}:\d{1,2}$/.test(timeSpanInput)) {
                    return false;
                }

                // Lấy giá trị giờ, phút và giây từ chuỗi
                var parts = timeSpanInput.split(":");
                var hours = parseInt(parts[0]);
                var minutes = parseInt(parts[1]);
                var seconds = parseInt(parts[2]);

                // Kiểm tra giá trị hợp lệ cho giờ, phút và giây
                if (hours < 0 || minutes < 0 || minutes >= 60 || seconds < 0 || seconds >= 60) {
                    return false;
                }

                return true;
            }
            setTimeout(function () {
                $("#selectChannel").select2({
                    templateResult: formatState,
                    templateSelection: formatState

                });
            }, 100);

        });
        function formatState(opt) {
            if (!opt.id) {
                return opt.text;
            }
            var optimage = $(opt.element).data('image');
            if (!optimage) {
                return opt.text;
            } else {
                var $opt = $(
                    '<span><img src="' + optimage + '" width="23px" /> ' + opt.text + '</span>'
                );
                return $opt;
            }

        };

        //signalR
        $(document).ready(function () {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("https://apiytb.shinemusicllc.com/webHub")
                .withAutomaticReconnect()
                .configureLogging(signalR.LogLevel.Information)
                .build();

            async function start() {
                try {
                    await connection.start();
                    console.log("SignalR Connected.");
                } catch (err) {
                    console.log(err);
                    setTimeout(start, 5000);
                }
            };

            connection.onclose(async () => {
                await start();
            });

            // Start the connection.
            start();

            connection.on("RenderInfo", (renderInfo) => {
                //let rowIndex = `#row${renderInfo.id}`
                //console.log(renderInfo);
                //let id = renderInfo.id;
                //let index = $(rowIndex).attr('data-index');

                //console.log(index);
                //$.ajax({
                //    type: "POST",
                //    url: `/render/UpdateData?index=${index}`,
                //    data: renderInfo,
                //    success: function (response) {
                //        console.log(response);

                //        var d = $(response, 'td').map(function (i, td) {
                //            return td.textContent
                //        })

                //        tableRenders.row(rowIndex).data(d).invalidate().draw()
                //        //tableRenders.row(`.renderInfo_${id}`).data(d).invalidate().draw()
                //        // $(`.renderInfo_${id}`).html(response);
                //    }
                //});
            });

        });
        var lockResolver;
        if (navigator && navigator.locks && navigator.locks.request) {
            const promise = new Promise((res) => {
                lockResolver = res;
            });

            navigator.locks.request('unique_lock_name', { mode: "shared" }, () => {
                return promise;
            });
        }
