@using BaseSource.SharedSignalrData.Enums;
@using BaseSource.ViewModels.Render;
@model RenderHistoryDto

<td> @ViewBag.Index </td> <td> <span class="">@Model.CreatedTime.ToString("dd/MM/yyyy HH:mm:ss")</span> </td> <td> <span class="text-danger">@Model.BotName</span> </td> <td><img width="35" height="35" src="@Model.Avatar" /></td> <td> <span class="">@Model.ChannelName</span> </td> <td><a href="https://www.youtube.com/channel/@(Model.ChannelYTId)">@Model.ChannelYTId</a></td> <td> @if (!string.IsNullOrEmpty(Model.VideoLink)) { <a href="@Model.VideoLink">@Model.VideoLink</a> } </td> <td>@Model.TimeRender</td> <td>@Model.DownloadStartTime?.ToString("dd/MM/yyyy: HH:mm:ss")</td> <td>@Model.UploadStartTime?.ToString("dd/MM/yyyy: HH:mm:ss")</td> <td>@Model.UploadTimeCompleted?.ToString("dd/MM/yyyy: HH:mm:ss")</td> <td> @switch (Model.Status) { case WorkStatus.Queueing: <span class="badge badge-warning">Queueing</span> break; case WorkStatus.Downloading: <span class="badge badge-primary">Downloading (@(Model.Pencent)%)</span> break; case WorkStatus.Rendering: <span class="badge badge-primary">Rendering (@(Model.Pencent)%)</span> break; case WorkStatus.Uploading: <span class="badge badge-info">Uploading (@(Model.Pencent)%)</span> break; case WorkStatus.Completed: <span class="badge badge-success">Completed</span> break; case WorkStatus.Cancelled: <span class="badge badge-danger">Cancelled</span> break; case WorkStatus.Error: <span class="badge badge-danger">Error - (@Model.ErrorMessage)</span> break; } </td> <td> @if (Model.Status != WorkStatus.Completed && Model.Status != WorkStatus.Error && Model.Status != WorkStatus.Cancelled && Model.Status != WorkStatus.Pending ) { <button class="btn btn-sm btn-danger " data-id="@Model.Id" onclick="stop('@Model.Id');"> Dừng </button> } else if (Model.Status == WorkStatus.Pending) { <button class="btn btn-sm btn-success" onclick="start('@Model.Id');" data-id="@Model.Id"> Chạy </button> } <a href="/render/info?id=@Model.Id" class="btn btn-sm btn-primary">Xem cài đặt</a> </td>
