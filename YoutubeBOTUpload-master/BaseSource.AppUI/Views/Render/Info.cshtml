@using BaseSource.ViewModels.Render;
@model RenderHistoryDto
@{
    ViewData["Title"] = "Thông tin Render";
}

<section class="section">
    <div class="section-header">
        <h1>Cấu hình</h1>
        <div class="section-header-breadcrumb">
            <div class="breadcrumb-item active"><a href="#">Dashboard</a></div>
            <div class="breadcrumb-item"><a href="#">Cấu hình</a></div>
            <div class="breadcrumb-item">@ViewData["Title"]</div>
        </div>
    </div>
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">

                <div class="card">
                    <form asp-action="Clone" class="needs-validation" novalidate="">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="card-header">
                            <h4>Cấu hình</h4>
                        </div>
                        <div class="card-body">
                            <div class="section-title">Cấu hình Render</div>
                            <input name="Id" type="hidden" value="@Model.Id" />
                            <div class="form-group">
                                <label>Link video Intro</label>
                                <input asp-for="Intro" readonly placeholder="Đặt tên để gợi nhớ" class="form-control" id="linkVideoIntro">
                                <span asp-validation-for="Intro" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label>Link video loop <span class="text-danger"> * Bắt buộc</span> </label>
                                <input class="form-control" readonly required asp-for="VideoLoop" rows="1" id="linkVideoLoop" />
                                <span asp-validation-for="VideoLoop" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label>Link audio loop</label>
                                <input class="form-control" readonly asp-for="AudioLoop" rows="1" id="linkAudioLoop" />
                                <span asp-validation-for="AudioLoop" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label>Link Outro</label>
                                <input class="form-control" readonly name="Outtro" asp-for="Outtro" id="linkOutro" required />
                                <span asp-validation-for="Outtro" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label>Chọn Kênh</label>
                                <select class="form-control" disabled>
                                    <option>@Model.ChannelName - @Model.ChannelId</option>
                                </select>
                                
                                <span asp-validation-for="ChannelId" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label>Thời gian Render <span class="text-danger"> *Vui lòng nhập đúng định dạng</span></label>
                                <input class="form-control" readonly placeholder="00:00:00"  value="@Model.TimeRender" required />
                                <span asp-validation-for="TimeRender" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label>Hẹn lịch <span class="text-danger"></span></label>
                                <input class="form-control" readonly type="datetime-local" asp-for="ScheduleTime"  />
                                <span asp-validation-for="ScheduleTime" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label>Tên video upload</label>
                                <input class="form-control" readonly name="VideoName" asp-for="VideoName" required />
                                <span asp-validation-for="VideoName" class="text-danger"></span>
                            </div>

                        </div>
                        @*<div class="card-footer text-left">
                            <button class="btn btn-primary">Render lại</button>
                        </div>*@
                    </form>
                </div>
            </div>
        </div>


    </div>
</section>
@section Scripts{
    <script>
        function myFunction() {
            $('#StartTimeLive').val('');
            $('#EndTimeLive').val('');
        }

    </script>
}