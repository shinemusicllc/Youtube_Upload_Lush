<Window x:Class="UploadYoutubeBot.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UploadYoutubeBot.UI"
        xmlns:ViewModels="clr-namespace:UploadYoutubeBot.UI.ViewModels"
        xmlns:Xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:WpfUiControl="clr-namespace:TqkLibrary.WpfUi.UserControls;assembly=TqkLibrary.WpfUi"
        xmlns:WpfUiConveter="clr-namespace:TqkLibrary.WpfUi.Converters;assembly=TqkLibrary.WpfUi"
        xmlns:st="http://schemas.spicytaco.io/"
        mc:Ignorable="d"
        Title="UploadYoutubeBot" WindowStartupLocation="CenterScreen" Height="600" Width="1100">
    <Window.Resources>
        <WpfUiConveter:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <ViewModels:ListViewYoutubeChannelSettingUIProxy x:Key="ListViewYoutubeChannelSettingUIProxy"/>
    </Window.Resources>
    <Window.DataContext>
        <ViewModels:MainWVM/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <st:StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0" MarginBetweenChildren="5">
            <TextBlock VerticalAlignment="Center" Text="Số Luồng:"/>
            <Xceed:IntegerUpDown Minimum="1" Increment="1" Value="{Binding ThreadCount}" VerticalAlignment="Center" />
            <TextBlock VerticalAlignment="Center" Text="Api Domain:"/>
            <TextBox Text="{Binding ApiDomain}" VerticalAlignment="Center" MinWidth="150"
                     IsEnabled="{Binding IsWorking,Converter={StaticResource InverseBooleanConverter}}"/>
            <Button x:Name="btn_Start" Click="btn_Start_Click" Content="Start" VerticalAlignment="Center" Padding="10,0" 
                    IsEnabled="{Binding IsWorking,Converter={StaticResource InverseBooleanConverter}}"/>
            <Button x:Name="btn_Stop" Click="btn_Stop_Click" Content="Stop" VerticalAlignment="Center" Padding="10,0"
                    IsEnabled="{Binding IsWorking}"/>
            <TextBlock VerticalAlignment="Center" >
                <Run Text="Server Connection:"/>
                <Run Text="{Binding ConnectionState,Mode=OneWay}"/>
            </TextBlock>
        </st:StackPanel>
        <st:StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0" HorizontalAlignment="Right" MarginBetweenChildren="5">
            <TextBlock Text="Bot Id:" VerticalAlignment="Center"/>
            <TextBox Text="{Binding BotId,Mode=OneWay}" MinWidth="150" VerticalAlignment="Center" IsReadOnly="True"/>
            <Button Content="Copy" VerticalAlignment="Center" Padding="5,0" Command="{Binding CopyCommand}" CommandParameter="{Binding BotId,Mode=OneWay}"/>
        </st:StackPanel>

        <st:StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,0">
            <local:SearchUC SearchTextChange="SearchUC_SearchTextChange" Margin="0,0,5,0" st:StackPanel.Fill="Fill"/>
            <!--<Button x:Name="btn_Setting" Content="Setting" Click="btn_Setting_Click" Padding="10,0" Margin="0,2"/>-->
        </st:StackPanel>

        <ListView x:Name="lv_YoutubeChannels" Margin="5" Grid.Row="2" ItemsSource="{Binding YoutubeChannels}" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="STT" Width="{Binding Path=STT, Source={StaticResource ListViewYoutubeChannelSettingUIProxy},Mode=TwoWay}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding STT}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="{Binding Path=GroupName, Source={StaticResource ListViewYoutubeChannelSettingUIProxy},Mode=TwoWay}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader x:Name="lv_gridheader_Group" Click="lv_gridheader_Group_Click">
                                <TextBlock Text="Nhóm"/>
                            </GridViewColumnHeader>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <WpfUiControl:TextBlockEdit Text="{Binding GroupName}" MouseDown="TextBlockEdit_MouseDown" VerticalAlignment="Center" HorizontalAlignment="Stretch" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Email &#38; Tên kênh" Width="{Binding Path=ChannelInfo, Source={StaticResource ListViewYoutubeChannelSettingUIProxy},Mode=TwoWay}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Height="38" WpfUiControl:Spacing.Horizontal="5">
                                    <Image Source="{Binding ChromeProfileVM.Avatar}"/>
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" WpfUiControl:Spacing.Vertical="5">
                                        <TextBlock Text="{Binding ChromeProfileVM.Email}"/>
                                        <TextBlock Text="{Binding ChromeProfileVM.ChannelName}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Channel Id" Width="{Binding Path=ChannelId, Source={StaticResource ListViewYoutubeChannelSettingUIProxy},Mode=TwoWay}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <st:StackPanel Orientation="Horizontal" MarginBetweenChildren="3">
                                    <TextBox Text="{Binding ChannelId,Mode=OneWay}" VerticalAlignment="Center" IsReadOnly="True" st:StackPanel.Fill="Fill"/>
                                    <Button Content="Copy" VerticalAlignment="Center" Padding="5,0" Command="{Binding CopyCommand}" CommandParameter="{Binding ChannelId,Mode=OneWay}"/>
                                </st:StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Mở chrome" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding ChromeProfileVM.IsOpenChrome,Mode=OneWay}" IsEnabled="False" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Logs" Width="{Binding Path=Logs, Source={StaticResource ListViewYoutubeChannelSettingUIProxy},Mode=TwoWay}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TopLog,Mode=OneWay}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ContextMenu>
                <ContextMenu ItemsSource="{Binding YoutubeChannelMenus}">
                    <ContextMenu.Resources>
                        <ControlTemplate x:Key="MenuSeparatorTemplate">
                            <Separator  IsEnabled="False" />
                        </ControlTemplate>
                        <Image x:Key="imgCTX" x:Shared="false" Source="{Binding Path=ImageSource}"/>
                    </ContextMenu.Resources>
                    <ContextMenu.ItemContainerStyle>
                        <Style TargetType="{x:Type MenuItem}">
                            <Setter Property="Header" Value="{Binding Text}" />
                            <Setter Property="Icon" Value="{StaticResource imgCTX}"/>
                            <Setter Property="ItemsSource" Value="{Binding Childs}"/>
                            <EventSetter Event="MenuItem.Click" Handler="lv_YoutubeChannels_MenuItem_Click" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ''}" Value="{x:Null}">
                                    <Setter Property="Template" Value="{StaticResource MenuSeparatorTemplate}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContextMenu.ItemContainerStyle>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    <Setter Property="Visibility" Value="{Binding Visibility}"/>
                    <Setter Property="Height" Value="48"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <ListView Margin="5" Grid.Row="3" ItemsSource="{Binding Logs}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Logs" Width="1000">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Height" Value="22"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Window>
