<UserControl x:Class="UploadYoutubeBot.UI.SearchUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UploadYoutubeBot.UI"
             xmlns:ViewModels="clr-namespace:UploadYoutubeBot.UI.ViewModels"
             xmlns:Xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:WpfUiControl="clr-namespace:TqkLibrary.WpfUi.UserControls;assembly=TqkLibrary.WpfUi"
             xmlns:WpfUiConveter="clr-namespace:TqkLibrary.WpfUi.Converters;assembly=TqkLibrary.WpfUi"
             mc:Ignorable="d" 
             d:DesignHeight="20" d:DesignWidth="200">
    <UserControl.Resources>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="35"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center"/>
        <TextBox x:Name="TB_SearchRender" TextChanged="TB_SearchRender_TextChanged" TextWrapping="Wrap" Grid.Column="1" VerticalAlignment="Center" Margin="3,0"/>
        <Button x:Name="btn_Clear" Click="btn_Clear_Click" Grid.Column="2" Content="Clear" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
